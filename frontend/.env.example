# Copy to .env.local for local development.
#
# When running the frontend with `npm run dev` (port 3001) and the backend with
# `awsco serve` (port 3000), point the browser API client at the backend:
NEXT_PUBLIC_API_URL=http://localhost:3000
#
# Leave UNSET for the production Docker image — there the built frontend is
# served from the same origin as the API and requests stay relative.
